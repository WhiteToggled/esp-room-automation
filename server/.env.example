# COPY THIS into your .env
# PostgreSQL (local Docker service)
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_strong_password

# MQTT (local Mosquitto in Docker)
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_pass
MQTT_PORT=9001
MQTT_TRANSPORT=websockets
MQTT_TLS=false
MQTT_SYNC_TOPIC=nestboard/sync

# JWT
JWT_SECRET_KEY=change_this_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler
LOG_INTERVAL_MINUTES=5

# Admin user (created on first startup if admin doesn't exist)
ADMIN_PASSWORD=admin_pass

# OTA — set to your Cloudflare tunnel public URL
SERVER_BASE_URL=https://nestboard.iotpro.uk

# CORS — comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:8081

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=tunnel_token
