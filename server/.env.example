# Database
DB_PASSPHRASE=your_strong_db_passphrase_here

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883

# JWT
JWT_SECRET_KEY=your_random_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler
LOG_INTERVAL_MINUTES=5

# Admin credentials (only superuser — all other accounts are created via POST /users)
ADMIN_PASSWORD=your_admin_password_here
