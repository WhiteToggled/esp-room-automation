# Database
DB_PASSPHRASE=your_strong_db_passphrase_here

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=mqtt_user
MQTT_PASSWORD=your_mqtt_password_here
MQTT_SYNC_TOPIC=esp/sync

# JWT
JWT_SECRET_KEY=your_random_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler
LOG_INTERVAL_MINUTES=5

# Admin password (set on first startup; ignored if admin already exists in users.db)
ADMIN_PASSWORD=1234
