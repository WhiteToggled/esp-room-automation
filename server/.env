# Database
DB_PASSPHRASE=change_this_strong_db_passphrase

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883

# JWT
JWT_SECRET_KEY=change_this_to_a_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scheduler
LOG_INTERVAL_MINUTES=5

# Default admin/owner credentials (used only if not already in users.db)
ADMIN_PASSWORD=change_this_admin_password
OWNER_PASSWORD=change_this_owner_password
