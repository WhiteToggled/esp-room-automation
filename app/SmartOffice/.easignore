# EAS Build ignore — keeps the upload small (~source only).
# NOTE: when this file exists, EAS Build uses it INSTEAD of .gitignore, so this
# mirrors .gitignore and adds the local native/build caches. EAS regenerates the
# native projects from app.json and installs dependencies itself.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native / signing (never upload)
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.keystore
*.mobileprovision

# Metro
.metro-health-check*

# debug / logs
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# macOS / secrets
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

app-example

# generated native folders + build caches (regenerated by EAS)
/ios
/android
.gradle/
*.apk
*.aab
